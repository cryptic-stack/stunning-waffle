AUTH_MODE=header
AUTOMATION_API_KEYS_JSON={"dev-automation-key":{"user_id":"automation-dev","email":"automation@example.com","display_name":"Automation Dev"}}
TURN_PUBLIC_HOST=localhost
TURN_INTERNAL_HOST=coturn
TURN_EXTERNAL_IP=
TURN_USERNAME=browserlab
TURN_PASSWORD=change-me
TURN_TLS_ENABLED=false
WORKER_ALLOW_RUNTIME_IMAGE_RESOLUTION=false
WORKER_VERIFY_IMAGES_ON_STARTUP=true
WORKER_IMAGE=foss-browserlab-chromium-worker:latest
FIREFOX_WORKER_IMAGE=foss-browserlab-firefox-worker:latest
BRAVE_WORKER_IMAGE=foss-browserlab-brave-worker:latest
EDGE_WORKER_IMAGE=foss-browserlab-edge-worker:latest
VIVALDI_WORKER_IMAGE=foss-browserlab-vivaldi-worker:latest
UBUNTU_XFCE_WORKER_IMAGE=foss-browserlab-ubuntu-xfce-worker:latest
KALI_XFCE_WORKER_IMAGE=foss-browserlab-kali-xfce-worker:latest
WORKER_CPU_LIMIT=1.5
WORKER_MEMORY_LIMIT=2g
WORKER_PIDS_LIMIT=256
WORKER_READ_ONLY_ROOTFS=true
WORKER_TMPFS_SIZE_MB=512
WORKER_ALLOW_OUTBOUND_NETWORK=true
SWEEPER_INTERVAL_SECONDS=30
CLOSED_SESSION_RETENTION_SECONDS=900
